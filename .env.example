# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Any long random string (protects login sessions)
SECRET_KEY=change-this-to-a-long-random-string

# Password for the Logbook dashboard
DASHBOARD_PASSWORD=change-me

# Optional tuning (defaults shown)
# PRIMARY_THRESHOLD=0.65
# SECONDARY_THRESHOLD=0.55

# How many entries per page on the Logbook list
# PAGE_SIZE=25

# How many "related" result cards to show under the best match (0 = none)
# RELATED_RESULTS=2

# How search results animate in: classic (stagger fade) or branches
# (an amber branch grows and cards appear one by one)
# REVEAL_STYLE=classic

# Auto-commit problems.csv to git after every add/edit/delete
# (needs `git init` in this folder first)
# AUTO_GIT_COMMIT=true
